<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_DATABASE" value="cms_saas_platform_test"/>
        <env name="DB_USERNAME" value="cms_saas"/>
        <env name="DB_PASSWORD" value="sXsWYnydmRf2jXXrDl3r2mxTwib9RWf+86lc+eY0K7I="/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="REDIS_ENABLED" value="false"/>
        <!-- Deploy-path isolation: without these, tests inherit .env's LIVE
             docroot paths and publish-touching tests write into production
             web roots (observed: factory-slug dirs under public_html). -->
        <env name="PUBLISH_PATH" value="storage/framework/testing/publish"/>
        <env name="TENANT_BASE_PATH" value="storage/framework/testing/tenants"/>
        <!-- Staging isolation too: the staging dir is SHARED with production
             (same checkout). Test publishes flooded it and BuildRetention -
             seeing no live symlinks in the sandboxed PUBLISH_PATH - pruned
             builds live sites were serving (2026-07-22 outage). -->
        <env name="PUBLISH_STAGING_PATH" value="storage/framework/testing/builds"/>
        <env name="PUBLISH_ROLLBACK_PATH" value="storage/framework/testing/rollback"/>
        <env name="SITE_WIZARD_WORKSPACE_PATH" value="storage/framework/testing/site-wizard"/>
        <env name="SITE_FILES_PATH" value="storage/framework/testing/site-files"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
