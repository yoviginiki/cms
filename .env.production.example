# ===========================================
# CMS Platform — Production Environment
# ===========================================

APP_NAME="CMS Platform"
APP_ENV=production
APP_KEY=  # Generate with: php artisan key:generate
APP_DEBUG=false  # CRITICAL: Must be false in production
APP_URL=https://sys.ensodo.eu

# Database — User MUST NOT be a superuser (RLS requirement)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cms_saas_platform
DB_USERNAME=cms_saas
DB_PASSWORD=  # Use a strong, unique password

# Session Security
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true  # CRITICAL: Requires HTTPS
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=sys.ensodo.eu

# Sanctum
SANCTUM_STATEFUL_DOMAINS=sys.ensodo.eu

# Redis (optional — falls back to database queue/cache if disabled)
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=  # Set a password
REDIS_DB_DEFAULT=2
REDIS_DB_CACHE=3
REDIS_DB_SESSION=4
REDIS_DB_QUEUE=5
REDIS_PREFIX=cmssaas_

# Cache & Queue
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# Publishing
DEPLOY_STRATEGY=auto  # 'symlink' (VPS), 'rename' (shared hosting), or 'auto'
PUBLISH_PATH=  # Default: public_path('sites')

# Mail
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@ensodo.eu
MAIL_FROM_NAME="${APP_NAME}"

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning  # Don't log debug info in production
