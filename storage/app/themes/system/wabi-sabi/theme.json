{
    "name": "Wabi-Sabi",
    "version": "1.0.0",
    "description": "Minimal zen aesthetic inspired by Japanese wabi-sabi philosophy. Warm earth tones, generous whitespace, no shadows, zero border radius. Inspired by misotone.m-hand.co.jp.",
    "author": "Ensodo",
    "lang": "en",
    "fonts": [
        {
            "family": "Figtree",
            "weight": "300 700",
            "style": "normal",
            "display": "swap"
        },
        {
            "family": "Syncopate",
            "weight": "400 700",
            "style": "normal",
            "display": "swap"
        }
    ],
    "tokens": {
        "color-primary": "#358733",
        "color-primary-dark": "#2a6d28",
        "color-primary-light": "#6BB369",
        "color-secondary": "#B7AF96",
        "color-accent": "#358733",
        "color-text": "#201F1D",
        "color-heading": "#201F1D",
        "color-text-muted": "#7D7B7A",
        "color-text-inverse": "#F3F0EA",
        "color-link": "#358733",
        "color-link-hover": "#2a6d28",
        "text-decoration-link": "none",
        "text-decoration-link-hover": "none",
        "color-bg": "#F3F0EA",
        "color-bg-alt": "#E8E4DA",
        "color-bg-raised": "#FFFFFF",
        "color-bg-overlay": "rgba(69,64,48,0.8)",
        "color-bg-inverse": "#201F1D",
        "color-border": "#C7C0AB",
        "color-border-light": "#E8E4DA",
        "color-border-strong": "#7D7B7A",
        "color-success": "#358733",
        "color-warning": "#D1B342",
        "color-danger": "#EA3E38",
        "color-info": "#2174BC",

        "font-heading": "'Syncopate', sans-serif",
        "font-body": "'Figtree', system-ui, sans-serif",
        "font-mono": "'JetBrains Mono', monospace",
        "font-nav": "'Figtree', system-ui, sans-serif",
        "font-button": "'Figtree', system-ui, sans-serif",

        "font-size-xs": "0.7rem",
        "font-size-sm": "0.8rem",
        "font-size-base": "0.95rem",
        "font-size-lg": "1.05rem",
        "font-size-xl": "1.2rem",
        "font-size-2xl": "1.5rem",
        "font-size-3xl": "1.875rem",
        "font-size-4xl": "2.5rem",
        "font-size-5xl": "3.5rem",
        "font-weight-normal": "400",
        "font-weight-medium": "500",
        "font-weight-bold": "600",

        "line-height-body": "1.8",
        "line-height-heading": "1.3",
        "line-height-tight": "1.2",
        "line-height-normal": "1.6",
        "line-height-relaxed": "1.85",
        "letter-spacing-body": "0.02em",
        "letter-spacing-heading": "0.08em",
        "letter-spacing-tight": "0",
        "letter-spacing-normal": "0.02em",
        "letter-spacing-wide": "0.08em",
        "heading-weight": "400",

        "link-hover-opacity": "0.7",

        "nav-mode": "overlay",
        "nav-height": "80px",
        "nav-bg-blur": "16px",
        "nav-font-size": "0.7rem",
        "nav-font-weight": "400",
        "nav-tracking": "0.2em",
        "nav-transform": "uppercase",
        "nav-gap": "32px",
        "nav-logo-size": "11px",
        "nav-logo-weight": "400",
        "nav-logo-tracking": "0.3em",
        "nav-logo-transform": "uppercase",
        "nav-padding": "20px 0",

        "nav-overlay-bg": "rgba(69,64,48,0.85)",
        "nav-overlay-color": "#F3F0EA",
        "nav-overlay-hover-color": "#ffffff",
        "nav-overlay-font-size": "2.2rem",
        "nav-overlay-font-weight": "300",
        "nav-overlay-tracking": "0.05em",
        "nav-overlay-transform": "none",
        "nav-overlay-gap": "1rem",
        "nav-overlay-sub-font-size": "1.2rem",

        "footer-bg": "#E8E4DA",
        "footer-color": "#686459",
        "footer-border-color": "#C7C0AB",

        "btn-bg": "transparent",
        "btn-color": "#201F1D",
        "btn-border": "#201F1D",
        "btn-hover-bg": "#201F1D",
        "btn-hover-color": "#F3F0EA",
        "btn-padding": "12px 28px",
        "btn-font-weight": "400",
        "btn-tracking": "0.15em",
        "btn-transform": "uppercase",
        "btn-radius": "0",

        "card-border": "none",
        "content-max-width": "800px",
        "prose-max-width": "65ch",

        "space-1": "4px",
        "space-2": "8px",
        "space-3": "12px",
        "space-4": "16px",
        "space-6": "24px",
        "space-8": "32px",
        "space-10": "40px",
        "space-12": "48px",
        "space-16": "64px",

        "container-width": "1100px",
        "container-padding": "24px",
        "grid-gap": "24px",

        "border-radius-none": "0",
        "border-radius-sm": "0",
        "border-radius-md": "0",
        "border-radius-lg": "0",
        "border-radius-xl": "0",
        "border-radius-full": "9999px",

        "shadow-sm": "none",
        "shadow-md": "none",
        "shadow-lg": "none",
        "shadow-xl": "none",

        "transition-fast": "150ms ease",
        "transition-base": "300ms ease",
        "transition-slow": "500ms ease"
    }
}
